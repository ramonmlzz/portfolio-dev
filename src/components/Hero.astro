---
import SocialPill from "../components/SocialPill.astro";
import GitHubIcon from "../icons/GitHub.astro";
import MailIcon from "../icons/Mail.astro";
import InstagramIcon from "../icons/Instagram.astro";
---

<section
    class="w-full mx-auto lg:w-[1100px] py-15 lg:py-53 px-4 flex flex-col items-center"
>
    <div
        class="flex flex-col-reverse lg:flex-row items-center lg:items-start gap-12 lg:gap-16 w-full"
    >
        <div
            class="flex-1 flex flex-col items-center lg:items-start text-center lg:text-left"
        >
            <h1 class="text-white text-3xl md:text-5xl font-bold gap-y-2 pb-4">
                ¡Hola! Soy
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 via-sky-400 to-sky-500 animate-[pulse_6s_ease-in-out_infinite]"
                    >Alejandro Melgarejo</span
                >
            </h1>

            <div
                class="min-h-[2rem] mb-2 flex items-center justify-center lg:justify-start gap-1"
            >
                <h2
                    class="subtitle typed-text text-2xl md:text-2xl text-transparent bg-clip-text bg-gradient-to-r from-sky-500 via-sky-200 to-sky-500 animate-[pulse_6s_ease-in-out_infinite]"
                    aria-live="polite"
                    aria-atomic="true"
                >
                </h2>
                <span class="text-2xl text-blue-400 animate-pulse">|</span>
            </div>

            <h2
                class="text-lg md:text-xl text-wrap opacity-80 max-w-[600px] lg:max-w-none"
            >
                <span class="text-red-200"> De Paraguay </span>🇵🇾. <br />
                Construyo aplicaciones rápidas, escalables y enfocadas en resultados.
                <br />
                Desarrollo soluciones web que convierten ideas en productos reales.
                <br />
                Frontend moderno + backend sólido para proyectos reales.
            </h2>

            <nav
                class="flex flex-wrap gap-2 md:gap-x-3 mt-10 justify-center lg:justify-start"
            >
                <SocialPill
                    href="https://github.com/ramonmlzz"
                    aria-label="GitHub de Alejandro Melgarejo"
                >
                    <GitHubIcon class="size-4 md:size-5 text-white" />
                    GitHub
                </SocialPill>
                <SocialPill
                    href="mailto:alejandromelgarejodev@gmail.com"
                    aria-label="Correo electrónico de Alejandro Melgarejo"
                >
                    <MailIcon class="size-4 md:size-5 text-white" />
                    Correo
                </SocialPill>
                <SocialPill
                    href="https://www.instagram.com/alejandromlzz"
                    aria-label="Instagram de Alejandro Melgarejo"
                >
                    <InstagramIcon class="size-4 md:size-5 text-white" />
                    Instagram
                </SocialPill>
            </nav>
        </div>

        <div class="flex-shrink-0">
            <img
                class="rounded-full size-48 md:size-56 lg:size-64 object-cover border-4 border-white/10 shadow-xl"
                src="/alejandro/alejandro.webp"
                alt="Foto de Alejandro Melgarejo"
            />
        </div>
    </div>

    <script>
        const textos = [
            "Full Stack Web Developer",
            "Estudiante de Ingeniería Informática",
        ];
        const typed = document.querySelector(".typed-text") as HTMLElement;
        let idxTexto = 0;
        let idxLetra = 0;
        let borrando = false;

        function escribir() {
            const textoActual = textos[idxTexto];
            if (!typed) return;

            if (borrando) {
                idxLetra--;
                typed.textContent = textoActual.substring(0, idxLetra);
                if (idxLetra === 0) {
                    borrando = false;
                    idxTexto = (idxTexto + 1) % textos.length;
                    setTimeout(escribir, 500);
                    return;
                }
            } else {
                idxLetra++;
                typed.textContent = textoActual.substring(0, idxLetra);
                if (idxLetra === textoActual.length) {
                    borrando = true;
                    setTimeout(escribir, 1500);
                    return;
                }
            }

            setTimeout(escribir, borrando ? 50 : 130);
        }

        if (typed) escribir();
    </script>
</section>
