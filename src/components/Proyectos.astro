---
import GitHubIcon from "../icons/GitHub.astro";

const projects = [
  {
    title: "Sistema de Ventas",
    description:
      "Sistema completo de punto de venta con gestión de caja, créditos, comisiones, devoluciones y módulo bancario. Construido con Java Swing y PostgreSQL.",
    image: "/proyectos/SafenexPOS.webp",
    tags: ["Java", "Swing", "PostgreSQL", "NetBeans"],
    github: "https://github.com/ramonmlzz/SafenexPOS",
    demo: "",
  },
  {
    title: "Portfolio Web",
    description:
      "Mi portfolio personal. Diseño oscuro moderno con texto animado, íconos sociales y componentes reutilizables.",
    image: "/proyectos/PortfolioWeb.webp", 
    tags: ["Astro", "TailwindCSS", "TypeScript"],
    github: "https://github.com/ramonmlzz/portfolio-dev",
    demo: "",
  },
];
---

<section id="proyectos" class="w-full mx-auto lg:w-[740px] py-16">
  <h2 class="text-3xl font-bold text-white mb-2">Proyectos</h2>
  <p class="text-white/50 mb-10 text-sm">
    Algunos de los proyectos que he construido.
  </p>

  <!-- Grid de proyectos -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    {
      projects.map((project) => (
        <article class="rounded-2xl border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 hover:border-white/20 transition-all duration-300 group flex flex-col">

          <!-- Preview del proyecto -->
          <div class="w-full h-44 overflow-hidden bg-white/5 relative">
            {project.image ? (
              <img
                src={project.image}
                alt={`Preview de ${project.title}`}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <!-- Placeholder si no hay imagen todavía -->
              <div class="w-full h-full flex items-center justify-center text-white/20 text-sm font-mono">
                sin preview
              </div>
            )}
          </div>

          <!-- Contenido de la tarjeta -->
          <div class="p-5 flex flex-col flex-1">

            <!-- Título + link GitHub -->
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="text-white font-semibold text-lg leading-tight">
                {project.title}
              </h3>
              <div class="flex items-center gap-2 flex-shrink-0 mt-0.5">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`GitHub de ${project.title}`}
                    class="text-white/50 hover:text-white transition-colors"
                  >
                    <GitHubIcon class="w-5 h-5" />
                  </a>
                )}
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Demo de ${project.title}`}
                    class="text-white/50 hover:text-white transition-colors"
                  >
                    <!-- Ícono de link externo -->
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Descripción -->
            <p class="text-white/60 text-sm leading-relaxed flex-1 mb-4">
              {project.description}
            </p>

            <!-- Tags de tecnologías -->
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="text-xs font-mono px-2 py-1 rounded-full border border-white/10 bg-white/5 text-white/70">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>