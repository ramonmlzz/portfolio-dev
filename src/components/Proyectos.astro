---
import GitHubIcon from "../icons/GitHub.astro";
import ViteIcon from "../icons/Vite.astro";
import AstroIcon from "../icons/Astroo.astro";
import ReactIcon from "../icons/React.astro";
import TailwindIcon from "../icons/Tailwind.astro";
import TypeScriptIcon from "../icons/TypeScript.astro";
import JavaScriptIcon from "../icons/JavaScript.astro";
import JavaIcon from "../icons/Java.astro";
import PostgreSQLIcon from "../icons/PostgreSQL.astro";
import NetBeansIcon from "../icons/NetBeans.astro";
import ExternalLinkIcon from "../icons/ExternalLink.astro";

const TAG_MAP = {
  ASTRO: {
    name: "Astro",
    icon: AstroIcon,
    class:
      "bg-[#ff5d05]/10 text-[#ff5d05] border-[#ff5d05]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  REACT: {
    name: "React",
    icon: ReactIcon,
    class:
      "bg-[#002244]/50 text-[#58c4dc] border-[#003d5c] transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  TAILWIND_CSS: {
    name: "Tailwind CSS",
    icon: TailwindIcon,
    class:
      "bg-sky-950/40 text-sky-200 border-sky-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  TYPE_SCRIPT: {
    name: "TypeScript",
    icon: TypeScriptIcon,
    class:
      "bg-[#002244]/50 text-[#5da9ff] border-[#003366] transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  JAVA_SCRIPT: {
    name: "JavaScript",
    icon: JavaScriptIcon,
    class:
      "bg-yellow-950/40 text-yellow-100 border-yellow-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  JAVA: {
    name: "Java",
    icon: JavaIcon,
    class:
      "bg-red-950/40 text-red-100 border-red-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  POSTGRESQL: {
    name: "PostgreSQL",
    icon: PostgreSQLIcon,
    class:
      "bg-slate-800/60 text-slate-100 border-slate-700 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  VITE: {
    name: "Vite",
    icon: ViteIcon,
    class:
      "bg-[#646cff]/10 text-[#646cff] border-[#646cff]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
  NETBEANS: {
    name: "NetBeans",
    icon: NetBeansIcon,
    class:
      "transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
  },
};

const projects = [
  {
    title: "PORTFOLIO WEB",
    description:
      "Mi portfolio personal. Diseño oscuro moderno con texto animado, íconos sociales y componentes reutilizables.",
    image: "/proyectos/PortfolioWeb.webp",
    tags: [TAG_MAP.ASTRO, TAG_MAP.TAILWIND_CSS, TAG_MAP.TYPE_SCRIPT],
    github: "https://github.com/ramonmlzz/portfolio-dev",
    demo: "",
  },
  {
    title: "El JUEGO DE LOS REYES",
    description:
      "Enciclopedia interactiva de ajedrez construida con React y Vite. Incluye historia del juego, piezas, grandes maestros, reglas y un visor de aperturas animado con movimientos paso a paso.",
    image: "/proyectos/ChessWeb.webp",
    tags: [TAG_MAP.REACT, TAG_MAP.VITE, TAG_MAP.JAVA_SCRIPT],
    github: "https://github.com/ramonmlzz/chess-app",
    demo: "https://chess-app-eight-green.vercel.app/",
  },
  {
    title: "SISTEMA DE PUNTO DE VENTA",
    description:
      "Sistema completo de punto de venta con gestión de caja, créditos, comisiones, devoluciones y módulo bancario. Construido con Java Swing y PostgreSQL.",
    image: "/proyectos/SafenexPOS.webp",
    tags: [TAG_MAP.JAVA, TAG_MAP.POSTGRESQL, TAG_MAP.NETBEANS],
    github: "https://github.com/ramonmlzz/SafenexPOS",
    demo: "",
  },
];
---

<section
  id="proyectos"
  class="w-full mx-auto lg:w-[1170px] pt-45 pb-20 px-4 lg:py-45 lg:px-0 flex flex-col items-center"
>
  <h2
    class="flex items-center text-3xl font-bold tracking-tight gap-x-3 text-white"
  >
    <svg
      class="size-7"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
        d="M15 12h.01"></path><path d="M12 12h.01"></path><path d="M9 12h.01"
      ></path><path d="M6 19a2 2 0 0 1 -2 -2v-4l-1 -1l1 -1v-4a2 2 0 0 1 2 -2"
      ></path><path d="M18 19a2 2 0 0 0 2 -2v-4l1 -1l-1 -1v-4a2 2 0 0 0 -2 -2"
      ></path></svg
    >
    Proyectos
  </h2>

  <p class="text-white/50 mb-10 text-md">
    Algunos de los proyectos que he construido.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      projects.map((project) => (
        <article class="rounded-2xl border border-white/10 bg-white/5 overflow-hidden hover:bg-white/10 hover:border-white/20 transition-all duration-300 group flex flex-col">
          <div class="w-full overflow-hidden bg-white/5 relative">
            {project.image ? (
              <img
                class="w-full h-50 object-cover object-top transition duration-500 group-hover:scale-105"
                src={project.image}
                alt={`Preview de ${project.title}`}
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-white/20 text-sm font-mono">
                sin preview
              </div>
            )}
          </div>

          <div class="p-5 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="text-white font-semibold text-lg leading-tight">
                {project.title}
              </h3>
              <div class="flex items-center gap-3 flex-shrink-0 mt-0.5">
                {" "}
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-white/50 hover:text-white transition-colors"
                    aria-label="Ver código en GitHub"
                  >
                    <GitHubIcon class="w-5 h-5" />
                  </a>
                )}
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-white/50 hover:text-white transition-colors"
                    aria-label="Ver sitio en vivo"
                  >
                    <ExternalLinkIcon class="w-5 h-5" />
                  </a>
                )}
              </div>
            </div>

            <p class="text-white/60 text-sm leading-relaxed flex-1 mb-4">
              {project.description}
            </p>

            <ul class="flex flex-wrap gap-x-2 gap-y-2.5 mt-auto">
              {project.tags.map((tag) => {
                const Icon = tag.icon;
                return (
                  <li
                    class={`flex items-center gap-x-2 rounded-full text-xs font-medium py-1 px-3 border transition-all ${tag.class}`}
                  >
                    <Icon class="w-3.5 h-3.5 flex-shrink-0" />
                    <span>{tag.name}</span>
                  </li>
                );
              })}
            </ul>
          </div>
        </article>
      ))
    }
  </div>
</section>
