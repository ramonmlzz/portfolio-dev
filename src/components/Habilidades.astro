---
import AstroIcon from "../icons/Astroo.astro";
import ReactIcon from "../icons/React.astro";
import TailwindIcon from "../icons/Tailwind.astro";
import JavaScriptIcon from "../icons/JavaScript.astro";
import JavaIcon from "../icons/Java.astro";
import PostgreSQLIcon from "../icons/PostgreSQL.astro";
import MySQLIcon from "../icons/MySQL.astro";
import GitHubIcon from "../icons/GitHub.astro";
import NetBeansIcon from "../icons/NetBeans.astro";
import ViteIcon from "../icons/Vite.astro";
import TypeScriptIcon from "../icons/TypeScript.astro";
import HTMLIcon from "../icons/HTML.astro";
import CSSIcon from "../icons/CSS.astro";
import NodeIcon from "../icons/Node.astro";
import PythonIcon from "../icons/Python.astro";
import GitIcon from "../icons/Git.astro";
import VSCodeIcon from "../icons/VSCode.astro";
import AccessIcon from "../icons/Access.astro";
import ClaudeIcon from "../icons/Claude.astro";

const TAG_MAP = {
    HTML: {
        name: "HTML",
        icon: HTMLIcon,
        class: "bg-orange-950/40 text-orange-100 border-orange-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    CSS: {
        name: "CSS",
        icon: CSSIcon,
        class: "bg-blue-950/40 text-blue-100 border-blue-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    ASTRO: {
        name: "Astro",
        icon: AstroIcon,
        class: "bg-[#ff5d05]/10 text-[#ff5d05] border-[#ff5d05]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    REACT: {
        name: "React",
        icon: ReactIcon,
        class: "bg-[#002244]/50 text-[#58c4dc] border-[#003d5c] transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    TAILWIND_CSS: {
        name: "Tailwind CSS",
        icon: TailwindIcon,
        class: "bg-sky-950/40 text-sky-200 border-sky-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    TYPE_SCRIPT: {
        name: "TypeScript",
        icon: TypeScriptIcon,
        class: "bg-[#002244]/50 text-[#5da9ff] border-[#003366] transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    JAVA_SCRIPT: {
        name: "JavaScript",
        icon: JavaScriptIcon,
        class: "bg-yellow-950/40 text-yellow-100 border-yellow-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    JAVA: {
        name: "Java",
        icon: JavaIcon,
        class: "bg-red-950/40 text-red-100 border-red-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    NODE: {
        name: "Node.js",
        icon: NodeIcon,
        class: "bg-green-950/40 text-green-100 border-green-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    PYTHON: {
        name: "Python",
        icon: PythonIcon,
        class: "bg-[#002244]/50 text-[#58c4dc] border-[#003d5c] transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    POSTGRESQL: {
        name: "PostgreSQL",
        icon: PostgreSQLIcon,
        class: "bg-slate-800/60 text-slate-100 border-slate-700 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    MYSQL: {
        name: "MySQL",
        icon: MySQLIcon,
        class: "bg-blue-950/40 text-blue-100 border-blue-800 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    ACCESS: {
        name: "Access",
        icon: AccessIcon,
        class: "bg-[#a61727]/10 text-[#a61727] border-[#a61727]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    GIT: {
        name: "Git",
        icon: GitIcon,
        class: "bg-gray-800/40 text-gray-100 border-gray-700 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    GITHUB: {
        name: "GitHub",
        icon: GitHubIcon,
        class: "bg-gray-800/40 text-gray-100 border-gray-700 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    VITE: {
        name: "Vite",
        icon: ViteIcon,
        class: "bg-[#646cff]/10 text-[#646cff] border-[#646cff]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    NETBEANS: {
        name: "NetBeans",
        icon: NetBeansIcon,
        class: "transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    VSCode: {
        name: "VS Code",
        icon: VSCodeIcon,
        class: "bg-[#007acc]/10 text-[#007acc] border-[#007acc]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
    CLAUDE: {
        name: "Claude",
        icon: ClaudeIcon,
        class: "bg-[#ff5d05]/10 text-[#ff5d05] border-[#ff5d05]/50 transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md",
    },
};

const skills = [
    {
        name: "Frontend",
        class: "text-transparent bg-clip-text bg-gradient-to-r from-blue-900 via-sky-500 to-cyan-300 animate-[pulse_6s_ease-in-out_infinite]",
        technologies: [
            TAG_MAP.HTML,
            TAG_MAP.CSS,
            TAG_MAP.JAVA_SCRIPT,
            TAG_MAP.ASTRO,
            TAG_MAP.REACT,
            TAG_MAP.TAILWIND_CSS,
            TAG_MAP.TYPE_SCRIPT,
        ],
    },
    {
        name: "Backend",
        class: "bg-gradient-to-r from-red-500 via-red-300 to-red-200 text-transparent bg-clip-text animate-[pulse_6s_ease-in-out_infinite]",
        technologies: [
            TAG_MAP.JAVA,
            TAG_MAP.NODE,
            TAG_MAP.PYTHON,
            TAG_MAP.POSTGRESQL,
            TAG_MAP.MYSQL,
            TAG_MAP.ACCESS,
        ],
    },
    {
        name: "Herramientas",
        class: "bg-gradient-to-r from-white via-slate-100 to-gray-400 text-transparent bg-clip-text animate-[pulse_6s_ease-in-out_infinite]",
        technologies: [
            TAG_MAP.GIT,
            TAG_MAP.GITHUB,
            TAG_MAP.VITE,
            TAG_MAP.NETBEANS,
            TAG_MAP.VSCode,
            TAG_MAP.CLAUDE,
        ],
    },
];
---

<section id="habilidades" class="w-full mx-auto lg:w-[1300px] py-20 px-1">
    <h2
        class="flex items-center text-3xl font-bold tracking-tight gap-x-3 text-white justify-center"
    >
        <span class="text-white/80">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="size-8"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                <path d="M7 8l-4 4l4 4"></path>
                <path d="M17 8l4 4l-4 4"></path>
                <path d="M14 4l-4 16"></path>
            </svg>
        </span>
        Habilidades
    </h2>
    <p class="text-white/50 mb-12 text-md flex flex-col items-center">
        Tecnologías y herramientas que domino.
    </p>

    <div class="px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
        {
            skills.map((skill) => (
                <div class="p-2 rounded-2xl border border-white/5 bg-black/10 gap-6">
                    <div>
                        <h3
                            class={
                                "p-2 text-xl text-center font-semibold mb-4 " +
                                skill.class
                            }
                        >
                            {skill.name}
                        </h3>
                        <div class="grid grid-cols-3 gap-3 justify-center">
                            {skill.technologies.map((tech) => (
                                <div class="flex flex-col items-center gap-2 px-4 py-2 rounded-lg transition-all duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md">
                                    <div>
                                        <tech.icon class="size-17" />
                                    </div>
                                    <div>
                                        <span class="text-sm">{tech.name}</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>
